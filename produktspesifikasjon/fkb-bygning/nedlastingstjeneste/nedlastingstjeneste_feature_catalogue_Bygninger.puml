@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title FKB-Bygning - nedlastingstjeneste - Bygninger

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Bygninger" {

  class AnnenBygning <<featureType>> {
    + område [1] : GM_Surface
    + posisjon [0..1] : GM_Point
    + medium [1] : Medium
  }

  class Bygning <<featureType>> {
    + område [0..1] : GM_Surface
    + posisjon [1] : GM_Point
    + bygningsnummer [1] : Integer
    + bygningstype [1] : Bygningstype
    + bygningsstatus [1] : Bygningsstatus
    + kommunenummer [1] : Kommunenummer
    + medium [1] : Medium
  }
}

package "Eksterne referanser" <<Frame>> {
  class Arkade <<BeskrivendeBygningslinjer>> {
  }
  class BygningBru <<Bygningsvedheng>> {
  }
  class BygningsavgrensningTiltak <<Bygningsavgrensning>> {
  }
  class Bygningsdelelinje <<Bygningsavgrensning>> {
  }
  class Bygningslinje <<BeskrivendeBygningslinjer>> {
  }
  class Fasadeliv <<Bygningsavgrensning>> {
  }
  class Fellesegenskaper <<Generelle elementer>> {
  }
  class FiktivBygningsavgrensning <<Bygningsavgrensning>> {
  }
  class Grunnmur <<Bygningsavgrensning>> {
  }
  class Hjelpelinje3D <<BeskrivendeBygningslinjer>> {
  }
  class Hjelpepunkt3D <<BeskrivendeBygningslinjer>> {
  }
  class "Låvebru" as L_vebru <<Bygningsvedheng>> {
  }
  class "Mønelinje" as M_nelinje <<BeskrivendeBygningslinjer>> {
  }
  class Portrom <<BeskrivendeBygningslinjer>> {
  }
  class TakMur <<BeskrivendeBygningslinjer>> {
  }
  class Takkant <<Bygningsavgrensning>> {
  }
  class "Takplatå" as Takplat_ <<BeskrivendeBygningslinjer>> {
  }
  class "TakplatåTopp" as Takplat_Topp <<BeskrivendeBygningslinjer>> {
  }
  class Taksprang <<BeskrivendeBygningslinjer>> {
  }
  class TaksprangBunn <<BeskrivendeBygningslinjer>> {
  }
  class TrappBygg <<Bygningsvedheng>> {
  }
  class "VeggFrittstående" as VeggFrittst_ende <<Bygningsvedheng>> {
  }
  class Veranda <<Bygningsvedheng>> {
  }
}

