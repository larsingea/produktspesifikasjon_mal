@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title FKB-Bygning - nedlastingstjeneste - Bygningsavgrensning

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Bygningsavgrensning" {

  class FiktivBygningsavgrensning <<featureType>> {
    + grense [1] : GM_Curve
    + medium [1] : Medium
  }

  class BygningsavgrensningTiltak <<featureType>> {
    + grense [1] : GM_Curve
    + medium [1] : Medium
    + høydereferanse [1] : Høydereferanse
    + lavestegulv [0..1] : Real
  }

  class Takkant <<featureType>> {
    + grense [1] : GM_Curve
    + medium [1] : Medium
    + treDNivå [1] : TreDNivå
    + takskjegg [0..1] : Integer
  }

  class Fasadeliv <<featureType>> {
    + grense [1] : GM_Curve
    + medium [1] : Medium
    + høydereferanse [1] : Høydereferanse
    + skalAvgrenseBygning [1] : Boolean
  }

  class Bygningsdelelinje <<featureType>> {
    + grense [1] : GM_Curve
    + treDNivå [1] : TreDNivå
  }

  class Grunnmur <<featureType>> {
    + grense [1] : GM_Curve
    + medium [1] : Medium
    + høydereferanse [1] : Høydereferanse
  }
}

package "Eksterne referanser" <<Frame>> {
  class Fellesegenskaper <<Generelle elementer>> {
  }
  class KvalitetOpsjonell <<Generelle elementer>> {
  }
  class "KvalitetPåkrevd" as KvalitetP_krevd <<Generelle elementer>> {
  }
}

KvalitetOpsjonell <|-- FiktivBygningsavgrensning
KvalitetOpsjonell <|-- BygningsavgrensningTiltak
KvalitetP_krevd <|-- Takkant
KvalitetP_krevd <|-- Fasadeliv
Fellesegenskaper <|-- Bygningsdelelinje
KvalitetP_krevd <|-- Grunnmur

@enduml
