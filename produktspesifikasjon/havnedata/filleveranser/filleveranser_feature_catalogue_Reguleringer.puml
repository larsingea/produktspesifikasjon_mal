@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Havnedata - Filleveranser - Reguleringer

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Reguleringer" {

  class FartsrestriksjonerGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class "ForbudsområdeGrense" as Forbudsomr_deGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class Fartsrestriksjoner <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + forskriftNavn [1] : CharacterString
    + gjelderForFartøytype [1..*] : Fartøytype
    + hastighet [1] : Integer
    + lovhjemmel [0..1] : CharacterString
    + periodeGyldigFra [0..1] : Date
    + periodeGyldigTil [0..1] : Date
    + fastsattAv [0..1] : CharacterString
    + forskriftLenke [0..1] : CharacterString
    + gjelderFor [0..1] : CharacterString
  }

  class "Forbudsområde" as Forbudsomr_de <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + fastsattAv [0..1] : CharacterString
    + forskriftLenke [0..1] : CharacterString
    + forskriftNavn [0..1] : CharacterString
    + gjelderFor [0..1] : CharacterString
    + gjelderForFartøytype [1..*] : Fartøytype
    + lovhjemmel [0..1] : CharacterString
    + periodeGyldigFra [0..1] : Date
    + periodeGyldigTil [0..1] : Date
    + forbudstype [1..*] : Forbudstype
  }
}

package "Eksterne referanser" <<Frame>> {
  class FellesegenskaperOpsjonell <<Generelle konsepter>> {
  }
  class "FellesegenskaperPåkrevd" as FellesegenskaperP_krevd <<Generelle konsepter>> {
  }
}

FellesegenskaperP_krevd <|-- FartsrestriksjonerGrense
FellesegenskaperP_krevd <|-- Forbudsomr_deGrense
FellesegenskaperOpsjonell <|-- Fartsrestriksjoner
Fartsrestriksjoner --> FartsrestriksjonerGrense : avgrensning [0..*]
FellesegenskaperOpsjonell <|-- Forbudsomr_de
Forbudsomr_de --> Forbudsomr_deGrense : avgrensning [0..*]

@enduml
