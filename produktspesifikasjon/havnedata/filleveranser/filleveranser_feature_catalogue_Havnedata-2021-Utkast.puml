@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Havnedata - Filleveranser - Havnedata-2021-Utkast

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Havnedata-2021-Utkast" {

  class "Havneområde" as Havneomr_de <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + forvaltesAv [0..1] : CharacterString
  }

  class Havneanlegg <<featureType>> {
    + eier [0..1] : CharacterString
    + eierskap [1..*] : Eierskap
    + forvaltesAv [0..1] : CharacterString
    + ISPSHavneanlegg [0..1] : ISPSHavneanlegg
    + område [1] : Flate
    + posisjon [0..1] : Punkt
  }

  class HavnegjerdeInngang <<featureType>> {
    + avsperringstype [1] : Avsperringstype
    + åpningstype [0..1] : Åpningstype
  }

  class Havnegjerde <<featureType>> {
    + senterlinje [1] : Kurve
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
    + periode [0..*] : Periode
  }

  class Drivstofftilkobling <<featureType>> {
    + posisjon [1] : Punkt
    + drivstofftype [1..*] : Drivstofftype
    + kapasitet [0..1] : Integer
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
    + mobilitet [1] : Boolean
    + tilgangstype [0..*] : Tilgangstype
  }

  abstract class ObjektId <<featureType>> {
    + objektLøpenummer [1] : CharacterString
  }

  class Kran <<featureType>> {
    + posisjon [1] : Punkt
    + krantype [1] : Krantype
    + maksbelastning [0..1] : Integer
    + rekkevidde [0..1] : Integer
    + maksbelastningRekkevidde [0..1] : Integer
    + høydereferanse [1] : Høydereferanse
    + kranspesifikasjon [0..1] : CharacterString
    + status [0..1] : Status
    + mobilitet [1] : Boolean
    + energikilde [0..*] : Energikilde
  }

  class Slipp <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + kaidekketype [0..1] : Kaidekketype
    + navn [0..1] : CharacterString
    + spesifikasjon [0..1] : CharacterString
    + høydereferanse [1] : Høydereferanse
    + høydeSjøkartnull [1] : Real
    + maksLengdeFartøy [0..1] : Real
    + status [0..1] : Status
    + tilgangstype [0..*] : Tilgangstype
    + slippKapasitet [0..1] : Integer
    + maksBreddeFartøy [0..1] : Real
    + maksDyptgåendeFartøy [0..1] : Real
    + kranKapasitet [0..1] : Integer
  }

  class "Tømmestasjon" as T_mmestasjon <<featureType>> {
    + høydereferanse [1] : Høydereferanse
    + kapasitet [0..1] : Integer
    + kumnummer [0..1] : Integer
    + posisjon [1] : Punkt
    + status [0..1] : Status
    + tilkoblingsdimensjon [0..1] : CharacterString
    + avløpstype [1..*] : Avløpstype
    + mobilitet [1] : Boolean
    + tilgangstype [0..*] : Tilgangstype
  }

  class FlytedokkGrense <<featureType>> {
    + grense [1] : Kurve
  }

  abstract class HavneanleggId <<featureType>> {
    + ISPS [0..1] : Boolean
    + havneanleggNavn [0..1] : CharacterString
    + havneanleggId [0..1] : CharacterString
  }

  class "Tørrdokk" as T_rrdokk <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + maksFartøyBredde [0..1] : Real
    + maksFartøyLengde [0..1] : Integer
    + maksFartøyDyptgående [0..1] : Real
    + løftekapasitet [0..1] : Integer
    + navn [0..1] : CharacterString
    + status [0..1] : Status
    + høydereferanse [1] : Høydereferanse
  }

  class Toalett <<featureType>> {
    + posisjon [1] : Punkt
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
  }

  class "ForvaltningsområdeGrense" as Forvaltningsomr_deGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class SlippGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class "TørrdokkGrense" as T_rrdokkGrense <<featureType>> {
    + grense [1] : Kurve
  }

  abstract class HavnId <<featureType>> {
    + havn [1] : CharacterString
    + UNLOCODE [1] : CharacterString
  }

  class Kamera <<featureType>> {
    ' Ingen attributter
  }

  class "Lastbegrensningsområde" as Lastbegrensningsomr_de <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + vektbegrensning [0..1] : Real
    + akseltrykk [0..1] : Real
    + minsteAvstandPunktlast [0..1] : Real
    + lastreferanse [0..1] : CharacterString
    + bruksklassetype [0..1] : Bruksklassetype
    + punktlast [0..1] : Real
    + kaidekketype [0..1] : Kaidekketype
    + lastId [0..1] : CharacterString
  }

  class "Kaiområde" as Kaiomr_de <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + kaitype [0..1] : Kaitype
    + kaidekketype [0..1] : Kaidekketype
  }

  class "KaiområdeGrense" as Kaiomr_deGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class Flytedokk <<featureType>> {
    + område [1] : Flate
    + posisjon [0..1] : Punkt
    + maksFartøyBredde [0..1] : Real
    + maksFartøyLengde [0..1] : Integer
    + maksFartøyDyptgående [0..1] : Real
    + løftekapasitet [0..1] : Integer
    + navn [0..1] : CharacterString
    + status [0..1] : Status
    + høydereferanse [1] : Høydereferanse
  }

  class Beredskapspunkt <<featureType>> {
    + posisjon [1] : Punkt
    + beredskapstype [1..*] : Beredskapstype
    + spesifikasjon [0..1] : CharacterString
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
  }

  class Havnesensor <<featureType>> {
    + posisjon [1] : Punkt
    + sensortype [0..1] : Sensortype
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
    + objektLøpenummer [0..1] : CharacterString
  }

  class ELkobling <<featureType>> {
    + posisjon [1] : Punkt
    + ELanleggstype [1..*] : ELanleggstype
    + rekkeviddeLadeanlegg [0..1] : Integer
    + tilgangstype [0..*] : Tilgangstype
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
    + ELkoblinger [0..*] : ELkoblingEgenskaper
  }

  class "Forvaltningsområde" as Forvaltningsomr_de <<featureType>> {
    + forvaltesAv [0..1] : CharacterString
    + område [1] : Flate
    + posisjon [0..1] : Punkt
  }

  class "HavneområdeGrense" as Havneomr_deGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class Fender <<featureType>> {
    + posisjon [0..1] : Punkt
    + fendertype [1] : Fendertype
    + fenderspesifikasjon [0..1] : CharacterString
    + høydeSjøkartnull [1] : Real
    + høydereferanse [1] : Høydereferanse
    + fenderorientering [1] : Fenderorientering
    + status [0..1] : Status
    + fendergruppering [0..1] : Kurve
    + antall [0..1] : Integer
  }

  class VAuttak <<featureType>> {
    + posisjon [1] : Punkt
    + VAuttakstype [1] : VAuttakstype
    + kapasitet [0..1] : Integer
    + tilkoblingsdimensjon [0..1] : CharacterString
    + høydereferanse [1] : Høydereferanse
    + kumnummer [0..1] : Integer
    + status [0..1] : Status
    + tilgangstype [0..*] : Tilgangstype
  }

  class HavneanleggGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class Avfallspunkt <<featureType>> {
    + posisjon [1] : Punkt
    + avfallstype [0..*] : Avfallstype
    + avfallsplan [0..1] : CharacterString
    + tilgangstype [0..*] : Tilgangstype
    + beholdertype [0..1] : Beholdertype
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
    + mobilitet [1] : Boolean
  }

  class "Fortøyningsinnretning" as Fort_yningsinnretning <<featureType>> {
    + posisjon [1] : Punkt
    + fortøyningstype [1] : Fortøyningstype
    + maksbelastning [0..1] : Integer
    + spesifikasjon [0..1] : CharacterString
    + høydereferanse [1] : Høydereferanse
    + status [0..1] : Status
    + høydeSjøkartnull [1] : Real
    + sertifiseringsdato [0..1] : Date
    + tillattFortøyningsvinkelGrunnriss [0..1] : CharacterString
    + tillattFortøyningsvinkelOppriss [0..1] : CharacterString
  }

  abstract class KaiId <<featureType>> {
    + kaiId [1] : CharacterString
    + kainavn [0..1] : CharacterString
    + kaiIdIntern [0..1] : CharacterString
  }

  class "LastbegrensningsområdeGrense" as Lastbegrensningsomr_deGrense <<featureType>> {
    + grense [1] : Kurve
  }

  class Kaifront <<featureType>> {
    + kaitype [1..*] : Kaitype
    + lengde [1] : Real
    + høydereferanse [1] : Høydereferanse
    + kaifronttype [1] : Kaifronttype
    + høydeSjøkartnull [1] : Real
    + senterlinje [1] : Kurve
    + status [0..1] : Status
  }

  class ISPSHavneanlegg <<dataType>> {
    + portFacilityNrIMO [1] : CharacterString
    + sikringstype [0..1] : Sikringstype
    + statusGodkjenning [0..1] : CharacterString
    + sikkerhetsbarriere [0..1] : Boolean
    + kontaktinformasjonPFSO [0..1] : CharacterString
  }

  class Periode <<dataType>> {
    + mndFra [1] : Måned
    + mndTil [1] : Måned
  }

  class ELkoblingEgenskaper <<dataType>> {
    + effekt [0..1] : Integer
    + frekvens [0..1] : Frekvens
    + spenning [0..1] : Spenning
    + sikringstørrelse [0..1] : Integer
    + kontaktId [0..1] : CharacterString
    + faser [0..1] : CharacterString
  }
}

package "Eksterne referanser" <<Frame>> {
  class FellesegenskaperOpsjonell <<Generelle konsepter>> {
  }
  class "FellesegenskaperPåkrevd" as FellesegenskaperP_krevd <<Generelle konsepter>> {
  }
}

HavnId <|-- Havneomr_de
Havneomr_de --> Havneomr_deGrense : avgrensning [0..*]
HavneanleggId <|-- Havneanlegg
Havneanlegg --> HavneanleggGrense : avgrensning [0..*]
Havnegjerde <|-- HavnegjerdeInngang
HavneanleggId <|-- Havnegjerde
ObjektId <|-- Drivstofftilkobling
KaiId <|-- ObjektId
ObjektId <|-- Kran
KaiId <|-- Slipp
Slipp --> SlippGrense : avgrensning [0..*]
ObjektId <|-- T_mmestasjon
FellesegenskaperP_krevd <|-- FlytedokkGrense
HavnId <|-- HavneanleggId
HavneanleggId <|-- T_rrdokk
T_rrdokk --> T_rrdokkGrense : avgrensning [0..*]
ObjektId <|-- Toalett
FellesegenskaperP_krevd <|-- Forvaltningsomr_deGrense
FellesegenskaperP_krevd <|-- SlippGrense
FellesegenskaperP_krevd <|-- T_rrdokkGrense
FellesegenskaperOpsjonell <|-- HavnId
Havnesensor <|-- Kamera
KaiId <|-- Lastbegrensningsomr_de
Lastbegrensningsomr_de --> Lastbegrensningsomr_deGrense : avgrensning [0..*]
KaiId <|-- Kaiomr_de
Kaiomr_de --> Kaiomr_deGrense : avgrensning [0..*]
FellesegenskaperP_krevd <|-- Kaiomr_deGrense
HavneanleggId <|-- Flytedokk
Flytedokk --> FlytedokkGrense : avgrensning [0..*]
ObjektId <|-- Beredskapspunkt
HavnId <|-- Havnesensor
ObjektId <|-- ELkobling
HavnId <|-- Forvaltningsomr_de
Forvaltningsomr_de --> Forvaltningsomr_deGrense : avgrensning [0..*]
FellesegenskaperP_krevd <|-- Havneomr_deGrense
ObjektId <|-- Fender
ObjektId <|-- VAuttak
FellesegenskaperP_krevd <|-- HavneanleggGrense
ObjektId <|-- Avfallspunkt
ObjektId <|-- Fort_yningsinnretning
HavneanleggId <|-- KaiId
FellesegenskaperP_krevd <|-- Lastbegrensningsomr_deGrense
ObjektId <|-- Kaifront

@enduml
