@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Marine landformer - Filleveranse - Objekttyper

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Objekttyper" {

  class Dataavgrensning <<featureType>> {
    + grense [1] : Kurve
    + identifikasjon [0..1] : Identifikasjon
  }

  class MarinLandskapsgrense <<featureType>> {
    + grense [1] : Kurve
    + identifikasjon [0..1] : Identifikasjon
  }

  class MarinLandskap <<featureType>> {
    + område [1] : Flate
    + landskapType [1] : LandskapType
    + landskapTypeNavn [1] : CharacterString
    + egnetMålestokk [0..1] : Integer
  }

  abstract class FellesegenskaperLosmasse <<featureType>> {
    + datauttaksdato [1] : Date
    + førsteDigitaliseringsdato [1] : Date
    + oppdateringsdato [0..1] : Date
    + kvalitet [1] : Posisjonskvalitet
    + medium [1] : Medium
    + mediumNavn [1] : CharacterString
    + opphav [1] : CharacterString
  }

  abstract class LosmasseGrense <<featureType>> {
    + geolPavisningstype [1] : GeolPavisningstype
    + geolPavisningstypeNavn [1] : CharacterString
    + temakvalitet [1] : TemaKvalitet
  }

  abstract class FellesegenskaperFlater <<featureType>> {
    + identifikasjon [1] : Identifikasjon
    + datauttaksdato [1] : Date
    + førsteDigitaliseringsdato [0..1] : Date
  }

  class Identifikasjon <<dataType>> {
    + lokalId [1] : CharacterString
    + navnerom [1] : CharacterString
    + versjonId [1] : CharacterString
  }

  class Posisjonskvalitet <<dataType>> {
    + målemetode [1] : Målemetode
    + målemetodeNavn [1] : CharacterString
    + nøyaktighet [0..1] : Integer
  }
}

  LosmasseGrense <|-- MarinLandskapsgrense
  FellesegenskaperFlater <|-- MarinLandskap
  MarinLandskap --> Dataavgrensning : avgrensning [0..*]
  MarinLandskap --> MarinLandskapsgrense : avgrensning [0..*]
  FellesegenskaperLosmasse <|-- LosmasseGrense

@enduml
