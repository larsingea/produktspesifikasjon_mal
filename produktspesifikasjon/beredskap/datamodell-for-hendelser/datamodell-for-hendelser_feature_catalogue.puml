    + prioritet [1] : PrioritetHendelse
    + kompleksitet [1] : Kompleksitet
    + aktørPerspektiv [1..*] : AktørPerspektiv
    + lokalitetstype [1] : Lokalitetstype
    + øvelse [1] : Boolean
    + identifikasjon [1] : uuid
    + betegnelse [0..1] : CharacterString
    + førsteRegistreringstidspunkt [1] : Date
