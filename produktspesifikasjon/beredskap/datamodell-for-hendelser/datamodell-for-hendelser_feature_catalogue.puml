    + førsteRegistreringstidspunkt [1] : Date
    + oppdateringstidspunkt [1] : Date
    + geometriobjekt [0..1] : URI
    + flate [0..1] : Flate
    + kurve [0..1] : Kurve
    + utbredelsestype [1] : TypeUtbredelse
    + beskrivelse [0..1] : CharacterString
  }

  class SammensattHendelse <<featureType>> {
