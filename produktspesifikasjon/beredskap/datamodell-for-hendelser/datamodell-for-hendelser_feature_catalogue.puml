  class Tiltakslokasjon <<featureType>> {
    + identifikasjon [1] : uuid
    + betegnelse [0..1] : CharacterString
    + førsteRegistreringstidspunkt [1] : Date
    + oppdateringstidspunkt [1] : Date
    + geometriobjekt [0..1] : URI
    + posisjon [1] : CharacterString
    + type [1] : TypeTiltakslokasjon
    + aktør [1] : Aktør
    + status [1] : Status
    + prioritetTilak [1] : Integer
    + typeFaresone [0..1] : TypeFaresone
    + typeRute [0..1] : TypeRute
