@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Tilfluktsrom - Offentlige - Datamodell for hendelser - Tiltak

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Tiltak" {

  class LokaltReferansesystem <<featureType>> {
    + navn [1] : CharacterString
    + typeReferansesystem [1] : TypeReferansesystem
  }

  class Tiltakslokasjon <<featureType>> {
    + posisjon [1] : GM_Object
    + type [1] : TypeTiltakslokasjon
    + aktør [1] : Aktør
    + status [1] : Status
    + prioritetTilak [1] : Integer
    + typeFaresone [0..1] : TypeFaresone
    + typeRute [0..1] : TypeRute
    + bevarÅsted [0..1] : Boolean
  }
}

package "Eksterne referanser" <<Frame>> {
  class Fellesegenskaper <<Geografiske hendelser>> {
  }
  class Ressurs <<Ressurser>> {
  }
}

Fellesegenskaper <|-- LokaltReferansesystem
Fellesegenskaper <|-- Tiltakslokasjon
Tiltakslokasjon --> Ressurs

@enduml
