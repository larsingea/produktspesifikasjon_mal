@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Tilfluktsrom - Offentlige - Datamodell for hendelser - Ressurser

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Ressurser" {

  abstract class Ressurs <<featureType>> {
    + posisjon [1] : GM_Point
    + aktør [1] : Aktør
    + ressursID [1] : CharacterString
    + estimertAnkomsttid [0..1] : Date
    + tilgjengelighetOps [1] : TilgjengelighetOps
    + tilgjengelighetHendelse [1] : TilgjengelighetHendelse
    + utstyr [0..*] : TypeUtstyr
  }

  class Drone <<featureType>> {
    + synsfelt [0..1] : Flate
    + dronetype [1] : TypeDrone
  }

  class Depot <<featureType>> {
    ' Ingen attributter
  }

  class AnnenRessurs <<featureType>> {
    + type [1] : TypeAnnenRessurs
  }

  class Transportmiddel <<featureType>> {
    + type [1] : TypeTransportmiddel
    + rolle [1] : TypeRolle
  }

  class Personell <<featureType>> {
    + rolle [0..1] : TypeRolle
    + typeEkspert [0..1] : TypeEkspert
  }
}

package "Eksterne referanser" <<Frame>> {
  class Fellesegenskaper <<Geografiske hendelser>> {
  }
  class Hendelse <<Hendelser>> {
  }
  class Tiltakslokasjon <<Tiltak>> {
  }
}

Fellesegenskaper <|-- Ressurs
Ressurs --> Hendelse : hendelse [0..1]
Ressurs --> Tiltakslokasjon : [0..*]
Ressurs <|-- Drone
Drone --> Personell : droneoperatør [0..1]
Ressurs <|-- Depot
Ressurs <|-- AnnenRessurs
Ressurs <|-- Transportmiddel
Ressurs <|-- Personell
Personell --> Transportmiddel : transportmiddel [0..1]

@enduml
