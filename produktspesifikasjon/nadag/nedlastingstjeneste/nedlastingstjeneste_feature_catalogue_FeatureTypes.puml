@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Nasjonal database for grunnundersøkelser (NADAG) - nedlastingstjeneste - FeatureTypes

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "FeatureTypes" {

  class Trykksondering <<featureType>> {
    + alpha [0..1] : Real
    + atmosferiskTrykkKorreksjon [0..1] : Real
    + cptKorreksjonsFaktor [0..1] : Real
    + filterType [0..1] : CharacterString
    + hylseRadieKorreksjon [0..1] : Real
    + initiellSpissmotstand [0..1] : Real
    + metningsMedium [0..1] : CharacterString
    + nedpressingsKapasitet [0..1] : NedpressingsKapasitet
    + nedpressningsHastighet [0..1] : Real
    + nullpunktsKorreksjon [0..1] : Real
    + rørKappeKorreksjonsFaktor [0..1] : Real
    + sidefriksjonKorreksjon [0..1] : Real
    + sondeIdentifikasjon [0..1] : CharacterString
    + sondeKalibreringDato [0..1] : Date
    + sondeKvalitetKlasse [0..1] : SondeKvalitetsKlasse
    + spissKorreksjonFaktor [0..1] : Real
    + spissType [0..1] : CharacterString
  }

  class Platebelastning <<featureType>> {
    + arealPlate [0..1] : Real
    + lasttrinnAntall [0..1] : Integer
  }

  class "GrunnvannMåling" as GrunnvannM_ling <<featureType>> {
    + erLangtidsobservasjon [1] : Boolean
    + filterDyp [0..1] : Real
    + filterLengde [0..1] : Real
    + filterType [0..1] : CharacterString
    + grunnvannAkvifer [0..1] : AkviferType
    + rørBunn [0..1] : Real
    + rørTopp [0..1] : Real
    + rørType [0..1] : CharacterString
  }

  class "GeotekniskUndersøkelseGrense" as GeotekniskUnders_kelseGrense <<featureType>> {
    ' Ingen attributter
  }

  class DilatometerTest <<featureType>> {
    + dilatometerModulus [0..1] : Real
    + horisontalSpenningIndeks [0..1] : Real
    + materialIndeks [0..1] : Real
  }

  class "StempelPrøve" as StempelPr_ve <<featureType>> {
    ' Ingen attributter
  }

  class "SedimentPrøve" as SedimentPr_ve <<featureType>> {
    ' Ingen attributter
  }

  class "RamPrøve" as RamPr_ve <<featureType>> {
    ' Ingen attributter
  }

  class KombinasjonSondering <<featureType>> {
    + boretLengdeIBerg [0..1] : Real
    + boretLengdeTilBerg [0..1] : BorlengdeTilBerg
    + maksLast [0..1] : Real
  }

  class GeotekniskTolketLag <<featureType>> {
    + eksternIdentifikasjon [0..1] : EksternIdentifikasjon
    + hovedLagKlassifiseringsKode [0..1] : HovedLagKlassifisering
    + høyde [0..1] : Real
    + høydeReferanse [0..1] : NADAG_Høyderef
    + klassifiseringMetode [0..1] : KlassifiseringsMetode
    + lagBeskrivelse [0..1] : CharacterString
    + navn [0..1] : CharacterString
    + posisjon [1] : Punkt
    + påTerrengOverflate [0..1] : Boolean
    + tolketAv [0..1] : CharacterString
    + tolketLagID [0..1] : CharacterString
    + tolketTidspunkt [0..1] : Date
    + tolkningMerknad [0..1] : CharacterString
    + underTerrengOverflate [0..1] : Boolean
    + vurdering [0..1] : Real
  }

  class GeotekniskDokument <<featureType>> {
    + beskrivelse [0..1] : CharacterString
    + dokumentDato [0..1] : Date
    + dokumentFilnavn [0..1] : CharacterString
    + dokumentID [0..1] : CharacterString
    + dokumentNavn [0..1] : CharacterString
    + dokumentNr [0..1] : CharacterString
    + dokumentNøkkel [0..1] : CharacterString
    + dokumentType [1] : NADAG_DokumentType
    + dokumentURL [0..1] : CharacterString
    + eksternIdentifikasjon [0..1] : EksternIdentifikasjon
    + innholdType [0..1] : CharacterString
    + opprettetDato [0..1] : Date
  }

  class "GassPrøve" as GassPr_ve <<featureType>> {
    ' Ingen attributter
  }

  class "VannPrøve" as VannPr_ve <<featureType>> {
    + vannPrøveType [0..1] : VannPrøveKilde
  }

  class "NaverPrøve" as NaverPr_ve <<featureType>> {
    ' Ingen attributter
  }

  class "GassMåling" as GassM_ling <<featureType>> {
    + byggNummer [0..1] : CharacterString
    + plassering [0..1] : CharacterString
  }

  class "SkovlPrøve" as SkovlPr_ve <<featureType>> {
    ' Ingen attributter
  }

  class StatiskSondering <<featureType>> {
    + telenivå [0..1] : Real
  }

  class GeotekniskTolketPunkt <<featureType>> {
    + beskrivelse [0..1] : CharacterString
    + digitaliseringsmålestokk [0..1] : Integer
    + høyde [0..1] : Real
    + høydeReferanse [0..1] : NADAG_Høyderef
    + identifikasjon [1] : Identifikasjon
    + kvalitet [0..1] : PosisjonskvalitetNADAG
    + navn [0..1] : CharacterString
    + oppdateringsdato [0..1] : Date
    + posisjon [1] : Punkt
    + tolketAv [0..1] : CharacterString
    + tolketTidspunkt [0..1] : Date
  }

  class KjerneBoring <<featureType>> {
    + boretLengdeTilBerg [0..1] : BorlengdeTilBerg
  }

  class GeotekniskBorehullUnders <<featureType>> {
    + dybdeGrunnvannstand [0..1] : Real
    + eksternIdentifikasjon [0..1] : EksternIdentifikasjon
    + forboretDiameter [0..1] : Real
    + forboretLengde [0..1] : Real
    + forboretStartLengde [0..1] : Real
    + forboringMetode [0..1] : CharacterString
    + geotekniskMetode [1] : GeotekniskMetodeKode
    + høyde [0..1] : Real
    + høydeReferanse [0..1] : NADAG_Høyderef
    + opprettetDato [1] : Date
    + stoppKode [0..1] : GeotekniskStoppkode
    + undersøkelseNr [0..1] : CharacterString
  }

  class "GeotekniskPrøveserie" as GeotekniskPr_veserie <<featureType>> {
    + erOmrørt [0..1] : Boolean
    + erUforstyrret [0..1] : Boolean
    + prøvegrop [0..1] : Boolean
    + prøvegropKun [0..1] : Boolean
    + skovelprøve [0..1] : Boolean
    + skovelprøveKun [0..1] : Boolean
  }

  class GeotekniskUnders <<featureType>> {
    + eksternIdentifikasjon [0..1] : EksternIdentifikasjon
    + opphav [0..1] : CharacterString
    + opprettetDato [1] : Date
    + prosjektNr [0..1] : CharacterString
    + representasjonKvalitet [0..1] : RepresentasjonKvalitet
    + undersøkelseÅrAntatt [0..1] : Integer
  }

  class "BlokkPrøve" as BlokkPr_ve <<featureType>> {
    ' Ingen attributter
  }

  class "MiljøUndersøkelse" as Milj_Unders_kelse <<featureType>> {
    ' Ingen attributter
  }

  class "KjernePrøve" as KjernePr_ve <<featureType>> {
    + boretLengdeTilBerg [0..1] : BorlengdeTilBerg
  }

  class GeotekniskFeltUnders <<featureType>> {
    + eksternidentifikasjon [0..1] : EksternIdentifikasjon
    + feltundersNr [0..1] : CharacterString
    + feltundersType [0..1] : FeltUndersTypeKode
    + geotekniskFeltUndersMetode [0..1] : GeotekniskFeltUndersMetodeKode
    + høyde [0..1] : Real
    + høydeFjell [0..1] : Real
    + høydeReferanse [0..1] : NADAG_Høyderef
    + identifikasjon [1] : Identifikasjon
    + opprettetDato [0..1] : Date
    + posisjon [1] : Punkt
    + tolkningMetode [0..1] : TolkningMetodeKode
  }

  class GeotekniskBorehull <<featureType>> {
    + boreNr [0..1] : CharacterString
    + eksternIdentifikasjon [0..1] : EksternIdentifikasjon
    + høyde [0..1] : Real
    + høydeReferanse [0..1] : NADAG_Høyderef
    + kvikkleirePåvisning [0..1] : KvikkleirePåvisningKode
    + maksBoretLengde [0..1] : Real
    + opphav [0..1] : CharacterString
    + opprettetDato [1] : Date
    + opprinneligGeotekniskUndersID [0..1] : CharacterString
  }

  class "GravePrøve" as GravePr_ve <<featureType>> {
    ' Ingen attributter
  }

  class DynamiskSondering <<featureType>> {
    + antPrøveuttakForstyrretMatr [0..1] : Integer
  }

  class "PoretrykkMåling" as PoretrykkM_ling <<featureType>> {
    + filterLengde [0..1] : Real
    + filterType [0..1] : CharacterString
    + installasjonTidspunkt [0..1] : Date
    + koteSpiss [0..1] : Real
    + målerKategori [0..1] : PoretrykkMåleKategori
    + målerspissNummer [0..1] : CharacterString
    + målerType [0..1] : CharacterString
    + rørBunn [0..1] : Real
    + rørTopp [0..1] : Real
    + rørToppFilter [0..1] : Real
    + rørToppSlange [0..1] : Real
  }

  class Vingeboring <<featureType>> {
    + vannstandIBorehull [0..1] : Real
    + vingeDiameter [0..1] : Real
    + vingeHøyde [0..1] : Real
    + vingeIdentitet [0..1] : CharacterString
  }

  class HydrauliskTest <<featureType>> {
    + rørBunn [0..1] : Real
    + rørTopp [0..1] : Real
    + rørType [0..1] : CharacterString
  }

  class "DeformasjonMåling" as DeformasjonM_ling <<featureType>> {
    + absoluttverdi [0..1] : Boolean
    + installasjonNivå [0..1] : Real
    + installasjonTidspunkt [0..1] : Date
    + målepunkt [0..1] : Real
    + målertype [0..1] : CharacterString
  }

  class "KannePrøve" as KannePr_ve <<featureType>> {
    ' Ingen attributter
  }

  class BorlengdeTilBerg <<dataType>> {
    + borlengdeKvalitet [1] : KvalitetBorlengdeTilBerg
    + borlengdeTilBerg [1] : Real
  }

  class EksternIdentifikasjon <<dataType>> {
    + eksternId [0..1] : CharacterString
    + eksternLeveringDato [0..1] : Date
    + eksternNavnerom [0..1] : CharacterString
    + eksternVersjonId [0..1] : CharacterString
  }

  class Identifikasjon <<dataType>> {
    + lokalId [1] : CharacterString
    + navnerom [1] : CharacterString
    + versjonId [0..1] : CharacterString
  }

  class PosisjonskvalitetNADAG <<dataType>> {
    + målemetode [1] : Målemetode
    + målemetodeHøyde [0..1] : MålemetodeHøyde
    + nøyaktighet [0..1] : Integer
    + nøyaktighetHøyde [0..1] : Integer
  }
}

package "Eksterne referanser" <<Frame>> {
  class "DeformasjonMåleData" as DeformasjonM_leData <<external>> {
  }
  class "DeformasjonOvervåkningData" as DeformasjonOverv_kningData <<external>> {
  }
  class DilatometerTestData <<external>> {
  }
  class DissipasjonData <<external>> {
  }
  class DynamiskSonderingData <<external>> {
  }
  class GassData <<external>> {
  }
  class GeotekniskInsituTest <<Abstrakte Featurtyper>> {
  }
  class GeotekniskObservasjon <<Abstrakte Featurtyper>> {
  }
  class "GeotekniskPrøvetaking" as GeotekniskPr_vetaking <<Abstrakte Featurtyper>> {
  }
  class GeotekniskSondering <<Abstrakte Featurtyper>> {
  }
  class Geotekniskmetode <<Abstrakte Featurtyper>> {
  }
  class "GeovitenskapeligUndersøkelse" as GeovitenskapeligUnders_kelse <<Abstrakte Featurtyper>> {
  }
  class "GeovitenskapeligUndersøkelseGrense" as GeovitenskapeligUnders_kelseGrense <<Abstrakte Featurtyper>> {
  }
  class GeovitenskapligBorehull <<Abstrakte Featurtyper>> {
  }
  class "GeovitenskapligBorehullUndersøkelse" as GeovitenskapligBorehullUnders_kelse <<Abstrakte Featurtyper>> {
  }
  class GrunnvannData <<external>> {
  }
  class HydrauliskeData <<external>> {
  }
  class KjerneBoringData <<external>> {
  }
  class KombinasjonSonderingData <<external>> {
  }
  class "OvervåkningData" as Overv_kningData <<external>> {
  }
  class PlatebelastningData <<external>> {
  }
  class PoretrykkData <<external>> {
  }
  class PoretrykkDataInsitu <<external>> {
  }
  class StatiskSonderingData <<external>> {
  }
  class TrykksonderingData <<external>> {
  }
  class VingeboringData <<external>> {
  }
}

GeotekniskInsituTest <|-- Trykksondering
Trykksondering --> DissipasjonData : dissipasjonObservasjon [0..*]
Trykksondering --> TrykksonderingData : trykksonderingObservasjon [0..*]
Trykksondering --> PoretrykkDataInsitu : inSituPoretrykkObservasjon [0..*]
GeotekniskInsituTest <|-- Platebelastning
Platebelastning --> PlatebelastningData : platebelastningObservasjon [0..*]
GeotekniskInsituTest <|-- GrunnvannM_ling
GrunnvannM_ling --> Overv_kningData : overvåkningObervasjon [0..*]
GrunnvannM_ling --> GrunnvannData : grunnvannObservasjon [0..*]
GeovitenskapeligUnders_kelseGrense <|-- GeotekniskUnders_kelseGrense
GeotekniskInsituTest <|-- DilatometerTest
DilatometerTest --> DilatometerTestData : dilatometerObservasjon [0..*]
GeotekniskPr_vetaking <|-- StempelPr_ve
GeotekniskPr_vetaking <|-- SedimentPr_ve
GeotekniskPr_vetaking <|-- RamPr_ve
GeotekniskSondering <|-- KombinasjonSondering
KombinasjonSondering --> KombinasjonSonderingData : kombinasjonSonderingObservasjon [0..*]
GeotekniskTolketLag --> GeotekniskTolketPunkt : tilhørerTolketPunkt [0..1]
GeotekniskDokument --> GeotekniskBorehullUnders : tilhørerGBU [0..1]
GeotekniskDokument --> GeotekniskBorehull : tilhørerGB [0..1]
GeotekniskDokument --> GeotekniskUnders : tilhørerGU [0..1]
GeotekniskDokument --> GeotekniskFeltUnders : tilhørerFeltUnders [0..1]
GeotekniskPr_vetaking <|-- GassPr_ve
GeotekniskPr_vetaking <|-- VannPr_ve
GeotekniskPr_vetaking <|-- NaverPr_ve
GeotekniskInsituTest <|-- GassM_ling
GassM_ling --> GassData : gassObservasjon [0..*]
GeotekniskPr_vetaking <|-- SkovlPr_ve
GeotekniskSondering <|-- StatiskSondering
StatiskSondering --> StatiskSonderingData : statiskSonderingObservasjon [0..*]
GeotekniskTolketPunkt --> GeotekniskBorehull : tilhørerGB [0..1]
GeotekniskTolketPunkt --> GeotekniskUnders : tilhørerGU [0..1]
GeotekniskPr_vetaking <|-- KjerneBoring
KjerneBoring --> KjerneBoringData : harData [0..*]
GeovitenskapligBorehullUnders_kelse <|-- GeotekniskBorehullUnders
GeotekniskBorehullUnders --> GeotekniskBorehull : undersPkt [0..1]
GeotekniskBorehullUnders --> Geotekniskmetode : metode [0..*]
GeotekniskPr_vetaking <|-- GeotekniskPr_veserie
GeovitenskapeligUnders_kelse <|-- GeotekniskUnders
GeotekniskUnders --> GeotekniskBorehull : undersPkt [0..*]
GeotekniskPr_vetaking <|-- BlokkPr_ve
GeotekniskPr_vetaking <|-- Milj_Unders_kelse
GeotekniskPr_vetaking <|-- KjernePr_ve
GeotekniskFeltUnders --> GeotekniskUnders : tilhørerGU [0..1]
GeovitenskapligBorehull <|-- GeotekniskBorehull
GeotekniskBorehull --> GeotekniskBorehullUnders : harUndersøkelse [0..*]
GeotekniskBorehull --> GeotekniskUnders : undersOmr [0..*]
GeotekniskPr_vetaking <|-- GravePr_ve
GeotekniskSondering <|-- DynamiskSondering
DynamiskSondering --> DynamiskSonderingData : dynamiskSonderingObservasjon [0..*]
GeotekniskInsituTest <|-- PoretrykkM_ling
PoretrykkM_ling --> PoretrykkData : poretrykkObservasjon [0..*]
GeotekniskInsituTest <|-- Vingeboring
Vingeboring --> VingeboringData : vingeboringObservasjon [0..*]
GeotekniskInsituTest <|-- HydrauliskTest
HydrauliskTest --> HydrauliskeData : hydrauliskObservasjon [0..*]
GeotekniskObservasjon <|-- DeformasjonM_ling
DeformasjonM_ling --> DeformasjonM_leData : harSetningObservasjon [0..*]
DeformasjonM_ling --> DeformasjonOverv_kningData : harOvervåkningObservasjon [0..*]
GeotekniskPr_vetaking <|-- KannePr_ve

@enduml
