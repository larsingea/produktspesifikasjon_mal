@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Nasjonal database for grunnundersøkelser (NADAG) - nedlastingstjeneste - Datatyper

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Datatyper" {

  class "GeotekniskPrøveseriedel" as GeotekniskPr_veseriedel <<featureType>> {
    + fraLengde [0..1] : Real
    + prøveMetode [0..1] : CharacterString
    + prøveseriedelId [1] : CharacterString
    + prøveseriedelNavn [0..1] : CharacterString
    + tilLengde [0..1] : Real
  }
}

package "Eksterne referanser" <<Frame>> {
  class "GeotekniskPrøveserie" as GeotekniskPr_veserie <<FeatureTypes>> {
  }
  class "GeotekniskPrøveseriedelData" as GeotekniskPr_veseriedelData <<external>> {
  }
}

GeotekniskPr_veseriedel --> GeotekniskPr_veserie : tilhørerPrøveserie [0..1]
GeotekniskPr_veseriedel --> GeotekniskPr_veseriedelData : harData [0..*]

@enduml
