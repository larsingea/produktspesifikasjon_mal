@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Naturhendelser - Filnedlasting - Oversikt

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Generelle elementer" {
  abstract class Fellesegenskaper <<featureType>> {
  }
}

package "Hendelser Test 20250620" {
  class "Risikoområde" as Risikoomr_de <<featureType>> {
  }
  class "BerørtOmråde" as Ber_rtOmr_de <<featureType>> {
  }
  class Hendelse <<featureType>> {
  }
  class Situasjon <<featureType>> {
  }
  class "Tiltaksområde" as Tiltaksomr_de <<featureType>> {
  }
  abstract class HendelseGenerell <<featureType>> {
  }
}


HendelseGenerell <|-- Risikoomr_de
HendelseGenerell <|-- Ber_rtOmr_de
HendelseGenerell <|-- Ber_rtOmr_de
HendelseGenerell <|-- Hendelse
HendelseGenerell <|-- Situasjon
Situasjon --> Ber_rtOmr_de : situasjonBerort [0..*]
Situasjon --> Hendelse : situasjonHendelse [0..*]
Situasjon --> Tiltaksomr_de : situasjonTiltak [0..*]
HendelseGenerell <|-- Tiltaksomr_de
Fellesegenskaper <|-- HendelseGenerell

@enduml
