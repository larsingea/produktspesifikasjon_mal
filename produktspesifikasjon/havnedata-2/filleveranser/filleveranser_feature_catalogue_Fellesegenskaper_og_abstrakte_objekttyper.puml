@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title Havnedata - Filleveranser - Fellesegenskaper og abstrakte objekttyper

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

package "Fellesegenskaper og abstrakte objekttyper" {

  abstract class HavneanleggId <<featureType>> {
    + havneanleggId [0..1] : CharacterString
    + havneanleggNavn [0..1] : CharacterString
    + ISPS [0..1] : Boolean
  }

  abstract class FellesegenskaperOpsjonell <<featureType>> {
    + informasjon [0..1] : CharacterString
    + link [0..1] : CharacterString
    + oppdateringsdato [0..1] : Date
  }

  abstract class "FellesegenskaperPåkrevd" as FellesegenskaperP_krevd <<featureType>> {
    + datafangstdato [1] : Date
    + identifikasjon [1] : Identifikasjon
    + kvalitet [1] : Posisjonskvalitet
  }

  abstract class HavnId <<featureType>> {
    + havn [1] : CharacterString
    + UNLOCODE [1] : CharacterString
  }

  abstract class KaiId <<featureType>> {
    + kaiId [1] : CharacterString
    + kaiIdIntern [0..1] : CharacterString
    + kainavn [0..1] : CharacterString
  }

  abstract class ObjektId <<featureType>> {
    + objektLøpenummer [1] : CharacterString
  }

  class Identifikasjon <<dataType>> {
    + lokalId [1] : CharacterString
    + navnerom [1] : CharacterString
    + versjonId [0..1] : CharacterString
  }

  class Posisjonskvalitet <<dataType>> {
    + datafangstmetode [1] : Datafangstmetode
    + datafangstmetodeHøyde [0..1] : Datafangstmetode
    + nøyaktighet [1] : Integer
    + nøyaktighetHøyde [0..1] : Integer
    + synbarhet [0..1] : Synbarhet
  }
}

HavnId <|-- HavneanleggId
FellesegenskaperP_krevd <|-- FellesegenskaperOpsjonell
FellesegenskaperOpsjonell <|-- HavnId
HavneanleggId <|-- KaiId
KaiId <|-- ObjektId

@enduml
